PORT=4000
NODE_ENV=development
SYNC_SERVER_TOKEN=replace-me
RECON_AUTH_SECRET=replace-with-a-long-random-secret

# Email used for reconciliation password-reset OTPs.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-me
SMTP_FROM=no-reply@example.com
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
COMPANY_NAME=SwiftCart
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_OTP_RESEND_SECONDS=60
PASSWORD_RESET_OTP_SECRET=replace-with-another-long-random-secret

DB_NAME=central_sync
DB_USER=sa
DB_PASSWORD=root
DB_HOST=localhost
DB_DIALECT=mysql
DB_POOL_MAX=15
DB_POOL_MIN=2
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

SAGE_BASE_URL=http://localhost:5000
SAGE_USERNAME=ADMIN
SAGE_PASSWORD=Admin123!
SAGE_TIMEOUT_MS=60000

WORKER_CONCURRENCY=2
SYNC_RECOVERY_BATCH_SIZE=250

# Reject reconciliation ranges whose raw event JSON exceeds this many bytes.
# This protects the API process until reporting reads from normalized tables.
RECON_MAX_PAYLOAD_BYTES=67108864
RECON_BACKFILL_BATCH_SIZE=25
# Keyset page size used when Excel exports read normalized report rows.
RECON_EXPORT_BATCH_SIZE=1000
