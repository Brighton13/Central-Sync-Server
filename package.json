{
  "name": "central-sync-server",
  "version": "1.0.0",
  "private": true,
  "description": "Central sync server for collecting POS events and dispatching Sage jobs",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:exe": "pkg . --targets node22-win-x64 --output dist/central-sync-server.exe"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bullmq": "^5.56.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "mysql2": "^3.14.1",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.10.1",
    "nodemon": "^3.1.10"
  },
  "pkg": {
    "targets": [
      "node22-win-x64"
    ],
    "scripts": [
      "server.js",
      "app.js",
      "models/**/*.js",
      "routes/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "queues/**/*.js",
      "workers/**/*.js"
    ],
    "assets": [
      "config/**/*",
      "models/**/*.js",
      "node_modules/mysql2/**/*"
    ]
  }
}
